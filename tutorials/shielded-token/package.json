{
  "name": "shielded-token-tutorial",
  "version": "1.0.0",
  "description": "Tutorial: Shielded Token Operations on Midnight - Mint, Transfer & Burn with Test Suite",
  "main": "managed/contract/index.js",
  "types": "managed/contract/index.d.ts",
  "scripts": {
    "compile": "/tmp/compactc --skip-zk contracts/Token.compact managed/",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "midnight",
    "compact",
    "shielded-token",
    "zero-knowledge",
    "privacy",
    "smart-contract",
    "tutorial"
  ],
  "author": "BossChaos",
  "license": "MIT",
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/tests"],
    "testMatch": ["**/*.test.ts"]
  }
}
